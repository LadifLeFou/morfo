# Morfo — modèle de configuration.
# Copiez ce fichier en `.env` puis remplissez les valeurs :  cp .env.example .env

# Backend (contrat §5)
MORFO_API_URL=https://api.morfo.app
SUPABASE_ANON_KEY=

# true = mock (aucun backend requis) · false = API réelle
MORFO_USE_MOCK=true

# Clés PUBLIQUES uniquement (jamais de secret de modèle IA côté app)
REVENUECAT_PUBLIC_SDK_KEY=
SUPERWALL_API_KEY=
